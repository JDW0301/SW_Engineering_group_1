  "meta": {
    "version": "3.1",
    "schema_version": "k-haters-v1",
    "description": "한국어 욕설/비속어/혐오표현 어휘 사전. 기존 공개 욕설 코퍼스에서 수집한 단어 목록에 K-HATERS 데이터셋의 분류 체계(offense_type, target)를 적용하여 구축된 하이브리드 사전이다.",
    "dataset_structure": {
      "overview": "이 사전은 두 가지 이질적인 자원을 결합한 하이브리드 구조이다: (1) 단어 수준의 욕설 코퍼스와 (2) K-HATERS의 문장 수준 혐오 분류 체계.",
      "word_source": "단어 목록은 직접 작성 및 오픈소스 한국어 욕설 데이터셋(LDNOOBW/ko, doublems/korean-bad-words)에서 수집·정제하였다. 이들은 단어 자체의 존재 여부(출현 빈도 기반)에 초점을 둔 필터링 목적 자료이다.",
      "classification_source": "각 단어에 부여된 offense_type과 target은 K-HATERS(Kim et al., 2022) 데이터셋의 문장 수준 annotation 체계를 단어 수준으로 투영(projection)한 것이다. K-HATERS의 원래 label은 문장 단위이지만, 여기서는 단어의 전형적 사용 맥락과 주 의미를 기준으로 하나의 대표 범주를 수동 부여하였다.",
      "design_rationale": "단어 목록과 분류 체계를 분리된 자원으로 결합한 이유: 기존 욕설 코퍼스는 다양하고 광범위하나 혐오 대상·유형 정보가 없고, K-HATERS는 정교한 분류 체계를 제공하지만 특정 발화 스타일(뉴스 댓글)에 편향되어 있다. 두 자원을 결합함으로써 폭넓은 어휘 커버리지와 혐오표현 유형별 필터링을 동시에 달성한다.",
      "limitations": "단어 수준의 offense_type/target은 문맥 독립적 단순화이다. 동일 단어도 문맥에 따라 범주가 달라질 수 있으며(예: '시발'은 감탄사로도 사용), 이는 상위 시스템의 문맥 분석(sLLM analyze_intent)으로 보완된다."
    },
    "k_haters_alignment": {
      "offense_types": {
        "욕설": "일반 욕설/비속어 (profanity)",
        "모욕": "특정 대상 비하/모욕 (insult)",
        "음란": "성적 음란 표현 (obscenity)",
        "위협": "위협/공격적 언어 (threat)"
